# .env — copy to .env and fill in your details
# Precision Swing Strategy (multi-timeframe confluence)

# ------------------------------------------------------------------ #
# Exchange credentials — MEXC (Spot Trade permission only, no withdrawal).
# Field names kept as BYBIT_* for backward compat — this is your real
# MEXC API key/secret, not a Bybit key. MEXC's minimum spot order size is
# $1 USDT, matching TRADE_USDT below. Note: MEXC spot has no exchange-side
# stop-loss support (see backend/exchange.py place_stop_loss) — the bot's
# only downside protection is its in-process ATR trailing stop, which only
# runs while this process is up.
# ------------------------------------------------------------------ #
BYBIT_API_KEY=your_mexc_api_key_here
BYBIT_API_SECRET=your_mexc_api_secret_here
SANDBOX_MODE=false

# ------------------------------------------------------------------ #
# Watchlist — high-volatility pairs with 4+ years of history
# ------------------------------------------------------------------ #
SYMBOLS=["ETH/USDT","SOL/USDT","AVAX/USDT","LINK/USDT"]

# ------------------------------------------------------------------ #
# Timeframes (read-only — set in config.py)
# ------------------------------------------------------------------ #
# TF_WEEKLY=1w
# TF_DAILY=1d
# TF_4H=4h
# TF_1H=1h
SCAN_INTERVAL_SECONDS=900     # 15 minutes

# ------------------------------------------------------------------ #
# Trade sizing
# ------------------------------------------------------------------ #
TRADE_USDT=1.0                # hard cap at $1.00

# ------------------------------------------------------------------ #
# Strategy — R:R gate and TSL
# ------------------------------------------------------------------ #
MIN_RR_RATIO=3.0              # minimum reward:risk to enter
ATR_1H_MULTIPLIER=1.5         # trailing stop = 1H ATR × this
TP1_POSITION_SIZE=0.5         # 50% closed at TP1 (fixed)

# ------------------------------------------------------------------ #
# Strategy — Fibonacci pullback zone
# ------------------------------------------------------------------ #
DAILY_PULLBACK_TOLERANCE=0.015  # price within 1.5% of fib level

# ------------------------------------------------------------------ #
# Strategy — RSI divergence
# ------------------------------------------------------------------ #
DIV_MAX_AGE_CANDLES=8         # candles back to search for divergence (on 4H)
DIV_MIN_RSI_LEVEL=50.0        # RSI at 2nd low must be below this

# ------------------------------------------------------------------ #
# Strategy — MACD + volume
# ------------------------------------------------------------------ #
VOLUME_WEAK_SELLER_RATIO=0.85 # green candle vol < 85% avg = weak sellers

# ------------------------------------------------------------------ #
# Hold time and rate limits
# ------------------------------------------------------------------ #
MAX_HOLD_HOURS=72             # TIMEOUT after 3 days
MAX_TRADES_PER_DAY=1          # one high-quality swing trade per day
MAX_DAILY_DRAWDOWN_PCT=0.05

# ------------------------------------------------------------------ #
# Entry order
# ------------------------------------------------------------------ #
ENTRY_ORDER_TIMEOUT_SECONDS=1800  # cancel limit buy if unfilled after 30 min

# ------------------------------------------------------------------ #
# Telegram notifications
# ------------------------------------------------------------------ #
TELEGRAM_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ------------------------------------------------------------------ #
# API server
# ------------------------------------------------------------------ #
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ------------------------------------------------------------------ #
# API auth — required by every /api request (header X-API-Key) and the
# /ws WebSocket (?api_key=...). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# If left blank, a random one is generated at startup and printed to the
# log — but it changes every restart, so set it explicitly for production.
# ------------------------------------------------------------------ #
API_AUTH_TOKEN=

# ------------------------------------------------------------------ #
# Database
# ------------------------------------------------------------------ #
DATABASE_URL=sqlite+aiosqlite:///./cryptobot.db
